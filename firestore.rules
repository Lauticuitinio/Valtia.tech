rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin email helper
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'valtyaanalytics@gmail.com';
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    // ── INVERSORES ──
    // Solo el admin puede leer todos los documentos.
    // Cada cliente solo puede leer y actualizar su propio documento.
    match /inversores/{email} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.token.email == email);
      allow write: if isAdmin();
    }

    // ── SOLICITUDES ──
    // Clientes autenticados pueden crear solicitudes propias y leer las suyas.
    // Solo el admin puede leer todas, actualizar estado (aprobar/rechazar).
    match /solicitudes/{solicitudId} {
      allow create: if isAuthenticated()
                    && request.resource.data.email == request.auth.token.email
                    && request.resource.data.tipo in ['deposito', 'rescate']
                    && request.resource.data.monto is number
                    && request.resource.data.monto > 0
                    && request.resource.data.estado == 'pendiente';

      allow read: if isAdmin()
                  || (isAuthenticated() && resource.data.email == request.auth.token.email);

      allow update: if isAdmin()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['estado'])
                    && request.resource.data.estado in ['aprobado', 'rechazado'];

      allow delete: if isAdmin();
    }

    // ── FONDO SYNC ──
    // Snapshot diario del fondo (IOL + Binance) escrito por fondo_sync.py
    // via Admin SDK (la escritura no pasa por estas reglas).
    match /fondoSync/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── METADATA DEL FONDO (Google Sheet: clientes, fee, historial) ──
    // Escrito por fondo_sync.py via Admin SDK. Solo el admin lo lee.
    match /fondoMeta/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── EVENTOS DEL FONDO (aportes/retiros anotados desde el panel admin) ──
    // El admin los crea desde la web; fondo_sync.py los consolida en el
    // Google Sheet y los marca como aplicados (via Admin SDK).
    match /fondoEventos/{docId} {
      allow read, create, update, delete: if isAdmin();
    }

    // ── CARTERAS MODELO (producto: carteras vivas) ──
    // Escritas por el admin / fondo_sync (Admin SDK). Las de visibilidad
    // "publico" las ve cualquiera; el resto requiere login (PRO a futuro).
    match /carterasModelo/{id} {
      allow read: if resource.data.visibilidad == 'publico' || isAuthenticated();
      allow write: if isAdmin();
      match /posiciones/{p} { allow read: if true; allow write: if isAdmin(); }
      match /historial/{h}  { allow read: if true; allow write: if isAdmin(); }
      match /valores/{v}    { allow read: if true; allow write: if isAdmin(); }
    }

    // ── SEÑALES Y RÉGIMEN DE MERCADO (sistema de rotación) ──
    // Calculado a diario por fondo_sync.py. Privado del gestor por ahora
    // (a futuro: producto PRO con visibilidad por plan).
    match /mercado/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── NOTICIAS PÚBLICAS (sección Noticias del sitio) ──
    // Solo las publicadas son visibles (query con filtro estado). El admin
    // gestiona borradores vía Admin SDK / consola.
    match /noticias/{docId} {
      allow read: if resource.data.estado == 'publicado' || isAdmin();
      allow write: if isAdmin();
    }

    // ── INFORMES DE RESEARCH ──
    // Los "publico" los ve cualquiera; los "clientes" requieren login.
    // Escritos por el admin / seed via Admin SDK.
    match /informes/{docId} {
      allow read: if resource.data.visibilidad == 'publico' || isAuthenticated();
      allow write: if isAdmin();
    }

    // ── NOTICIAS DEL FONDO ──
    // Briefings diarios generados por la tarea de Cowork, copiados por
    // fondo_sync.py via Admin SDK. Solo el admin las ve.
    match /noticiasFondo/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
